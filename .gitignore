# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you probably do not want to file track this.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if lock is generated on windows, it may fail on mac/linux.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended, but can be ignored.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended, but can be ignored.
#   pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

